# Livewire UI — Convenciones

## Estructura de un componente CRUD estándar

```php
<?php

namespace App\Livewire\Core;

use Livewire\Component;
use Livewire\WithPagination;
use App\Models\Core\Terlec;

class AbmCiclosLectivos extends Component
{
    use WithPagination;

    // Filtros
    public string $buscar = '';

    // Estado del modal
    public bool $modalAbierto = false;
    public bool $confirmandoBaja = false;
    public ?int $editandoId = null;

    // Campos del formulario
    public int $ano = 0;
    public int $orden = 1;

    protected function rules(): array
    {
        return [
            'ano'    => 'required|integer|min:2000|max:2100',
            'orden'  => 'required|integer|min:1',
        ];
    }

    public function render()
    {
        $items = Terlec::when($this->buscar, fn($q) => $q->where('ano', 'like', "%{$this->buscar}%"))
            ->orderBy('orden')
            ->paginate(15);

        return view('livewire.core.abm-ciclos-lectivos', compact('items'))
            ->layout('layouts.staff');
    }

    public function nuevo(): void
    {
        $this->resetForm();
        $this->modalAbierto = true;
    }

    public function editar(int $id): void
    {
        $item = Terlec::findOrFail($id);
        $this->editandoId = $id;
        $this->ano = $item->ano;
        $this->orden = $item->orden;
        $this->modalAbierto = true;
    }

    public function guardar(): void
    {
        $this->validate();
        // ...crear o actualizar
        $this->dispatch('toast', type: 'success', message: 'Guardado correctamente.');
        $this->modalAbierto = false;
    }

    public function confirmarBaja(int $id): void
    {
        // Validar dependencias antes de mostrar confirmación
        $this->editandoId = $id;
        $this->confirmandoBaja = true;
    }

    public function eliminar(): void
    {
        // Borrar y resetear
    }

    private function resetForm(): void
    {
        $this->editandoId = null;
        $this->ano = date('Y');
        $this->orden = 1;
        $this->resetValidation();
    }
}
```

